<?xml version="1.0"?>
<ruleset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         name="FieldForge"
         xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/PHPCSStandards/PHP_CodeSniffer/master/phpcs.xsd">

    <description>FieldForge coding standards — WordPress Coding Standards.</description>

    <!-- What to scan -->
    <file>fieldforge.php</file>
    <file>includes</file>
    <file>admin</file>

    <!-- Exclusions -->
    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>node_modules/*</exclude-pattern>
    <exclude-pattern>build/*</exclude-pattern>
    <exclude-pattern>tests/*</exclude-pattern>

    <!-- WordPress Coding Standards -->
    <rule ref="WordPress">
        <!-- File naming: class files use class-*.php which is correct but PHPCS flags it -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName" />
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase" />
        <!-- Doc comments on every method/variable are aspirational; exclude for now -->
        <exclude name="Squiz.Commenting.FunctionComment" />
        <exclude name="Squiz.Commenting.ClassComment" />
        <exclude name="PEAR.Commenting.ClassComment" />
        <exclude name="Squiz.Commenting.VariableComment.Missing" />
        <exclude name="Squiz.Commenting.VariableComment.MissingShort" />
        <exclude name="Generic.Commenting.DocComment.MissingShort" />
        <!-- Mixing a helper function with a class in one file is common in WP plugins -->
        <exclude name="Universal.Files.SeparateFunctionsFromOO" />
        <!-- VIP-specific exclusions not applicable to standard plugins -->
        <exclude name="WordPress.Security.EscapeOutput.HeredocFound" />
    </rule>

    <!-- Text domain: use element syntax (required for PHPCS 3.3+) -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="fieldforge" />
            </property>
        </properties>
    </rule>

    <!-- Line length: warn at 120, hard-fail at 200 -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120" />
            <property name="absoluteLineLimit" value="200" />
        </properties>
    </rule>

</ruleset>
